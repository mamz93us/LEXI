APP_NAME=LEXA
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Cairo
APP_URL=http://lexa.test

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_EG

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (Docker Compose service "postgres") ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=lexa
DB_USERNAME=lexa
DB_PASSWORD=lexa

# --- Tenancy ---
# Central (landlord) domain; tenants are reached as {slug}.{TENANT_DOMAIN}
TENANT_DOMAIN=lexa.test
CENTRAL_DOMAIN=lexa.test

# --- Sessions / cache / queue (all redis in dev + prod) ---
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# --- Redis (Docker Compose service "redis") ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Meilisearch (Docker Compose service "meilisearch") ---
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=lexa-dev-master-key
MEILISEARCH_PORT=7700

# --- Mail (replace with SES/SMTP in prod) ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@lexa.app"
MAIL_FROM_NAME="${APP_NAME}"

# --- S3-compatible object storage (placeholder; configure in Phase 2) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- AI (server-side only; never expose to frontend) ---
# Use Anthropic's zero-retention tier. Leave blank until Phase 2.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_ZERO_RETENTION=true

# Embedding provider — driver name + key. Final model TBD after Phase 2 quality eval.
EMBEDDINGS_DRIVER=cohere
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=embed-multilingual-v3.0
EMBEDDINGS_DIMENSION=1024

# --- WhatsApp (Green API; configure in Phase 2/3) ---
GREEN_API_INSTANCE=
GREEN_API_TOKEN=

# --- Billing (Paymob / Fawry; Phase 4) ---
PAYMOB_API_KEY=
FAWRY_MERCHANT_CODE=
FAWRY_SECURITY_KEY=

VITE_APP_NAME="${APP_NAME}"
