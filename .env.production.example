APP_NAME=LEXA
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Africa/Cairo
APP_URL=https://lexi.deevar.cloud

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_EG

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Trust the cPanel/Apache proxy chain so request()->isSecure() is true ---
TRUSTED_PROXIES=*
TRUSTED_HOSTS=lexi.deevar.cloud,*.lexi.deevar.cloud

# --- Database (Postgres installed via deploy/provision.sh) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=lexa
DB_USERNAME=lexa
DB_PASSWORD=

# --- Tenancy ---
TENANT_DOMAIN=lexi.deevar.cloud
CENTRAL_DOMAIN=lexi.deevar.cloud

# --- Sessions / cache / queue (all redis on prod) ---
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.lexi.deevar.cloud
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# --- Redis (provisioned on 127.0.0.1) ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Meilisearch ---
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# --- Mail (configure SES SMTP relay, Mailgun, or cPanel's mail) ---
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@lexi.deevar.cloud"
MAIL_FROM_NAME="${APP_NAME}"

# --- S3-compatible object storage (Phase 2 documents + RAG archive) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- AI (server-side only; never expose to frontend) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_ZERO_RETENTION=true

# Embedding provider — set after the retrieval-quality eval.
EMBEDDINGS_DRIVER=null
EMBEDDINGS_MODEL=embed-multilingual-v3.0
EMBEDDINGS_DIMENSION=1024
EMBEDDINGS_API_KEY=

# --- WhatsApp (Green API; Phase 2/3) ---
GREEN_API_INSTANCE=
GREEN_API_TOKEN=

# --- Billing (Paymob / Fawry; Phase 4) ---
PAYMOB_API_KEY=
FAWRY_MERCHANT_CODE=
FAWRY_SECURITY_KEY=

VITE_APP_NAME="${APP_NAME}"
